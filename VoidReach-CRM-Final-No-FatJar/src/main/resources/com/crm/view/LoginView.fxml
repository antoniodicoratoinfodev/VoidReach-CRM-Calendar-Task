<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.crm.controller.LoginController" styleClass="auth-page">
    <VBox maxWidth="430" spacing="20" styleClass="auth-card">
        <VBox alignment="CENTER" spacing="8"><FontIcon iconLiteral="fas-satellite" iconSize="38" iconColor="#60a5fa"/><Label text="VoidReach CRM" styleClass="auth-brand"/><Label text="Accedi al tuo spazio di lavoro" styleClass="auth-subtitle"/></VBox>
        <VBox fx:id="loginPane" spacing="12"><Label text="Bentornato" styleClass="auth-title"/><TextField fx:id="loginEmail" promptText="Email"/><PasswordField fx:id="loginPassword" promptText="Password" onAction="#handleLogin"/><CheckBox fx:id="rememberLogin" text="Resta connesso su questo dispositivo" styleClass="auth-checkbox"/><Label fx:id="loginMessage" styleClass="auth-message" wrapText="true"/><Button text="Accedi" onAction="#handleLogin" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Password dimenticata?" onAction="#showRecovery"/><HBox alignment="CENTER"><Label text="Non hai un account?"/><Hyperlink text="Registrati" onAction="#showRegister"/></HBox></VBox>
        <VBox fx:id="registerPane" visible="false" managed="false" spacing="12"><Label text="Crea un account" styleClass="auth-title"/><TextField fx:id="registerName" promptText="Nome e cognome"/><TextField fx:id="registerEmail" promptText="Email"/><PasswordField fx:id="registerPassword" promptText="Password (minimo 8 caratteri)"/><PasswordField fx:id="registerPasswordConfirm" promptText="Conferma password" onAction="#handleRegister"/><Label fx:id="registerMessage" styleClass="auth-message" wrapText="true"/><Button text="Crea account" onAction="#handleRegister" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Hai già un account? Accedi" onAction="#showLogin"/></VBox>
        <VBox fx:id="recoveryPane" visible="false" managed="false" spacing="12"><Label text="Recupera password" styleClass="auth-title"/><Label text="Inserisci l'email dell'account. In produzione il codice verrà inviato via email." wrapText="true" styleClass="auth-subtitle"/><TextField fx:id="recoveryEmail" promptText="Email" onAction="#handleRecovery"/><Label fx:id="recoveryMessage" styleClass="auth-message" wrapText="true"/><Button text="Genera codice" onAction="#handleRecovery" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Torna all'accesso" onAction="#showLogin"/></VBox>
        <VBox fx:id="resetPane" visible="false" managed="false" spacing="12"><Label text="Nuova password" styleClass="auth-title"/><TextField fx:id="resetEmail" promptText="Email" editable="false"/><TextField fx:id="resetCode" promptText="Codice a 6 cifre"/><PasswordField fx:id="resetPassword" promptText="Nuova password"/><PasswordField fx:id="resetPasswordConfirm" promptText="Conferma nuova password" onAction="#handleReset"/><Label fx:id="resetMessage" styleClass="auth-message" wrapText="true"/><Button text="Aggiorna password" onAction="#handleReset" maxWidth="1.7976931348623157E308" styleClass="auth-primary"/><Hyperlink text="Torna all'accesso" onAction="#showLogin"/></VBox>
    </VBox>
</StackPane>
